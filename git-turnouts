}

# Config check subcommand - check tool dependencies
cmd_config_check() {
  # Parse flags
  local VERBOSE=false
  local REQUIRED_ONLY=false
  local OPTIONAL_ONLY=false

  for arg in "$@"; do
    case "$arg" in
      --verbose|-v)
        VERBOSE=true
        ;;
      --required|-r)
        REQUIRED_ONLY=true
        ;;
      --optional|-o)
        OPTIONAL_ONLY=true
        ;;
      --help|-h)
        show_config_check_usage
        exit 0
        ;;
      *)
        echo "❌ Error: Unknown option '$arg'"
        show_config_check_usage
        exit 1
        ;;
    esac
  done

  # Cannot use both filters
  if [ "$REQUIRED_ONLY" = true ] && [ "$OPTIONAL_ONLY" = true ]; then
    echo "❌ Error: Cannot use both --required and --optional"
    exit 1
  fi

  # Define tool lists
  local required_tools="git bash jq"
  local optional_tools="gh shellcheck"

  # Header
  echo "📋 Tool Dependency Status"
  echo ""

  # Check required tools
  local required_missing=0
  if [ "$OPTIONAL_ONLY" = false ]; then
    echo "Required Tools:"
    if [ "$VERBOSE" = true ]; then
      printf "      %-13s %-22s\n" "Tool" "Version"
      echo "  ─────────────────────────────────────────────────"
    else
      printf "      %-13s %-22s %s\n" "Tool" "Version" "Purpose"
      echo "  ─────────────────────────────────────────────────────────────────────────────────────"
    fi
    for tool in $required_tools; do
      get_tool_info "$tool"
      print_tool_status "$tool" "$VERBOSE"
      if [ "$TOOL_INSTALLED" = false ]; then
        required_missing=$((required_missing + 1))
      fi
    done
    echo ""
  fi

  # Check optional tools
  if [ "$REQUIRED_ONLY" = false ]; then
    echo "Optional Tools:"
    if [ "$VERBOSE" = true ]; then
      printf "      %-13s %-22s\n" "Tool" "Version"
      echo "  ─────────────────────────────────────────────────"
    else
      printf "      %-13s %-22s %s\n" "Tool" "Version" "Purpose"
      echo "  ─────────────────────────────────────────────────────────────────────────────────────"
    fi
    for tool in $optional_tools; do
      get_tool_info "$tool"
      print_tool_status "$tool" "$VERBOSE"
    done
    echo ""
  fi

  # Summary
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  if [ "$REQUIRED_ONLY" = false ]; then
    if [ $required_missing -eq 0 ]; then
      echo "Status: All required tools are installed ✅"
    else
      echo "Status: Missing $required_missing required tool(s) ❌"
      echo ""
      echo "Run the installation commands above to fix missing dependencies."
      exit 1
    fi
  else
    echo "Status: Check complete"
  fi
}

