# ============================================================================
# VERIFY COMMAND
# ============================================================================

show_verify_usage() {
  cat << 'EOF'
Usage: git-turnouts verify [options]

Verify worktrees against remote branches and optionally clean up stale ones.

OPTIONS:
    --clean, -c       Remove worktrees with deleted remote branches
    --dry-run, -n     Preview what would be removed (implies --clean)
    --yes, -y         Skip confirmation prompt
    --verbose, -v     Show detailed status for each worktree
    --help, -h        Show this help message

EXAMPLES:
    git-turnouts verify                    # Check only (safe)
    git-turnouts verify --verbose          # Detailed output
    git-turnouts verify --clean --dry-run  # Preview cleanup
    git-turnouts verify --clean            # Clean with confirmation
    git-turnouts verify --clean --yes      # Clean without confirmation

EOF
}

handle_verify_cleanup() {
  local dry_run="$1"
  local force_yes="$2"

  echo ""

  # Show protected branches that will be skipped
  local protected_stale_count=$(echo "$WORKTREES_PROTECTED_STALE" | wc -w | tr -d ' ')
  if [ $protected_stale_count -gt 0 ]; then
    echo "🛡️  Protected branches (will be skipped):"
    for branch in $WORKTREES_PROTECTED_STALE; do
      # Extract path for this branch
      local path=""
      for entry in $WORKTREE_PATHS; do
        if [[ "$entry" == "$branch:"* ]]; then
          path="${entry#*:}"
          break
        fi
      done
      echo "   • $branch"
      echo "     Path: $path"
      echo "     Status: Remote deleted but branch is protected"
    done
    echo ""
  fi

  # Show non-protected stale worktrees
  local stale_count=$(echo "$WORKTREES_WITHOUT_REMOTE" | wc -w | tr -d ' ')
  if [ $stale_count -eq 0 ]; then
    echo "✨ No stale worktrees to remove"
    return 0
  fi

  echo "🗑️  Worktrees to remove:"

  # Show detailed list with warnings
  for branch in $WORKTREES_WITHOUT_REMOTE; do
    # Extract path for this branch
    local path=""
    for entry in $WORKTREE_PATHS; do
      if [[ "$entry" == "$branch:"* ]]; then
        path="${entry#*:}"
        break
      fi
    done

    echo "   • $branch"
    echo "     Path: $path"

    # Check for unpushed commits
    if check_unpushed_commits "$branch"; then
      echo "     ⚠️  WARNING: Has $UNPUSHED_COMMIT_COUNT unpushed commit(s)"
    fi
  done

  echo ""

  # Dry-run mode
  if [ "$dry_run" = "true" ]; then
    echo "🔍 DRY-RUN: No changes will be made"
    echo "   Run without --dry-run to actually remove"
    return 0
  fi

  # Determine if confirmation needed (always ask unless --yes flag)
  local need_confirmation=true
  if [ "$force_yes" = "true" ]; then
    need_confirmation=false
  fi

  # Ask for confirmation
  if [ "$need_confirmation" = "true" ]; then
    echo -n "Remove these worktrees? [y/N] "
    read -r response
    if [[ ! "$response" =~ ^[Yy] ]]; then
      echo "❌ Cleanup cancelled"
      return 1
    fi
  fi

  # Remove worktrees
  echo ""
  echo "🗑️  Removing stale worktrees..."

  # Use existing remove_worktree function
  for branch in $WORKTREES_WITHOUT_REMOTE; do
    remove_worktree "$branch"
  done

  # Auto-prune
  local auto_prune=$(get_config "remove.auto_prune" "true")
  if [ "$auto_prune" = "true" ]; then
    echo ""
    echo "🔧 Pruning stale references..."
    git worktree prune
  fi

  echo ""
  echo "✅ Cleanup complete!"
}

cmd_verify() {
  # Parse flags
  local CLEAN_MODE=false
  local DRY_RUN=false
  local FORCE_YES=false
  local VERBOSE=false

  for arg in "$@"; do
    case "$arg" in
      --clean|-c)
        CLEAN_MODE=true
        ;;
      --dry-run|-n)
        DRY_RUN=true
        CLEAN_MODE=true  # Implied
        ;;
      --yes|-y)
        FORCE_YES=true
        ;;
      --verbose|-v)
        VERBOSE=true
        ;;
      --help|-h)
        show_verify_usage
        exit 0
        ;;
      *)
        echo "❌ Error: Unknown option '$arg'"
        show_verify_usage
        exit 1
        ;;
    esac
  done

  # Step 1: Update remote references (always enabled)
  echo "🔄 Updating remote references..."
  if git fetch origin --prune --quiet 2>/dev/null; then
    echo "✅ Remote references updated"
  else
    echo "⚠️  Warning: Failed to fetch remote (continuing with cached data)"
  fi
  echo ""

  # Step 2: Analyze worktrees
  echo "🔍 Checking worktrees against remote..."
  echo ""

  analyze_worktrees_remote_status "$VERBOSE"

  # Step 3: Display results
  local stale_count=$(echo "$WORKTREES_WITHOUT_REMOTE" | wc -w | tr -d ' ')
  local active_count=$(echo "$WORKTREES_WITH_REMOTE" | wc -w | tr -d ' ')
  local protected_stale_count=$(echo "$WORKTREES_PROTECTED_STALE" | wc -w | tr -d ' ')

  # Always show summary
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📊 Summary:"
  echo "   ✅ Active: $active_count"
  echo "   ❌ Stale: $stale_count"
  if [ $protected_stale_count -gt 0 ]; then
    echo "   🛡️  Protected (stale): $protected_stale_count"
  fi
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # Step 4: Handle cleanup or show status message
  if [ "$CLEAN_MODE" = "true" ] && [ $stale_count -gt 0 ]; then
    handle_verify_cleanup "$DRY_RUN" "$FORCE_YES"
  elif [ "$CLEAN_MODE" = "true" ] && [ $stale_count -eq 0 ] && [ $protected_stale_count -gt 0 ]; then
    echo ""
    echo "✨ All stale worktrees are protected - nothing to remove!"
  elif [ $stale_count -eq 0 ] && [ $protected_stale_count -eq 0 ]; then
    echo ""
    echo "✨ All worktrees are up to date!"
  elif [ $stale_count -gt 0 ]; then
    echo ""
    echo "💡 Found $stale_count stale worktree(s) with deleted remote branches."
    echo "   Run 'git-turnouts verify --clean' to remove them."
    if [ $protected_stale_count -gt 0 ]; then
      echo "   Note: $protected_stale_count protected branch(es) will be skipped."
    fi
  fi
}

