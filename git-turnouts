# Helper function to get version string for a tool
get_tool_version() {
  local tool="$1"
  case "$tool" in
    git)
      git --version 2>/dev/null | sed 's/git version //' | awk '{print $1}'
      ;;
    jq)
      jq --version 2>/dev/null | sed 's/jq-//'
      ;;
    gh)
      gh --version 2>/dev/null | head -1 | sed 's/gh version //' | awk '{print $1}'
      ;;
    bash)
      bash --version 2>/dev/null | head -1 | sed 's/.*version //' | awk '{print $1}'
      ;;
    fzf)
      fzf --version 2>/dev/null | awk '{print $1}'
      ;;
    yq)
      yq --version 2>/dev/null | awk '{print $NF}'
      ;;
    shellcheck)
      shellcheck --version 2>/dev/null | grep '^version:' | awk '{print $2}'
      ;;
    *)
      echo "unknown"
      ;;
  esac
}

# Helper function to get full path to a tool
get_tool_path() {
  local tool="$1"
  command -v "$tool" 2>/dev/null || echo ""
}

# Helper function to check if a tool is installed
check_tool_installed() {
  local tool="$1"
  command -v "$tool" >/dev/null 2>&1
}

# Helper function to get all info about a tool
# Sets global variables: TOOL_INSTALLED, TOOL_VERSION, TOOL_PATH
get_tool_info() {
  local tool="$1"

  if check_tool_installed "$tool"; then
    TOOL_INSTALLED="true"
    TOOL_VERSION=$(get_tool_version "$tool")
    TOOL_PATH=$(get_tool_path "$tool")
  else
    TOOL_INSTALLED="false"
    TOOL_VERSION=""
    TOOL_PATH=""
  fi
}

# Helper function to get human-readable description of a tool
get_tool_purpose() {
  local tool="$1"
  case "$tool" in
    git)
      echo "Version control and worktree management"
      ;;
    jq)
      echo "JSON parsing for GitHub PR integration"
      ;;
    bash)
      echo "Script execution (requires 3.2+)"
      ;;
    gh)
      echo "GitHub Pull Request integration"
      ;;
    fzf)
      echo "Interactive branch selection (future feature)"
      ;;
    yq)
      echo "Advanced YAML configuration parsing (future feature)"
      ;;
    shellcheck)
      echo "Shell script linting for development"
      ;;
    *)
      echo "Unknown tool"
      ;;
  esac
}

# Helper function to get installation instructions for a tool
get_tool_install_instructions() {
  local tool="$1"
  case "$tool" in
    git)
      echo "  Install: https://git-scm.com/downloads"
      echo "  macOS:   brew install git"
      echo "  Linux:   apt-get install git or yum install git"
      ;;
    jq)
      echo "  Install: https://jqlang.github.io/jq/download/"
      echo "  macOS:   brew install jq"
      echo "  Linux:   apt-get install jq or yum install jq"
      ;;
    gh)
      echo "  Install: https://cli.github.com/"
      echo "  macOS:   brew install gh"
      echo "  Linux:   See https://github.com/cli/cli/blob/trunk/docs/install_linux.md"
      ;;
    fzf)
      echo "  Install: https://github.com/junegunn/fzf#installation"
      echo "  macOS:   brew install fzf"
      ;;
    yq)
      echo "  Install: https://github.com/mikefarah/yq#install"
      echo "  macOS:   brew install yq"
      ;;
